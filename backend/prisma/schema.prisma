generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Movie {
    id Int @id @default(autoincrement())
    title String?
    releaseDate DateTime @db.Date()
    genre String?
    price Decimal @db.Decimal(5, 2)
    @@map("movies")
}
