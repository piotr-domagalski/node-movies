<!DOCTYPE html>
<html>
    <head>
        <title> Movies App </title>
        <link rel="stylesheet" type="text/css" href="/style.css" title="CSS">
    </head>
    <body>
        <%- include('header', {}); %>
        <div class="page-card">
            <h2> <%= movie.title %> </h2>
            <ul>
                <li><b>Genre</b>: <%= movie.genre %>
                <li><b>Release date</b>: <%= movie.releaseDate %>
                <li><b>Price</b>: <%= movie.price %>
                <li><b>Rating</b>: <%= movie.rating %>
            </ul>
            <a href="/movies"> Return to list </a>
        </div>
        <%- include('footer', {}); %>
    </body>
</html>
